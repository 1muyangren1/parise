# ==============================================
# 树莓派 C++ / OpenCV / 无人机项目 专用 .gitignore
# 自动忽略：编译文件、临时文件、IDE文件、系统垃圾、测试文件
# ==============================================

# 1. C++ 编译产生的文件（必须忽略！）
build/
cmake-build-debug/
cmake-build-release/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.o
*.obj
*.so
*.a
*.out
*.elf
*.bin
*.hex

# 2. 可执行文件（你编译出来的程序）
*.exe
*.run
demo
test
main
camera
vision
drone
aruco
opticalflow

# 3. 编辑器 / IDE 临时文件
.idea/
.vscode/
*.swp
*.swo
*~
*.bak
*.tmp
.DS_Store
Thumbs.db

# 4. Python 缓存（如果你偶尔用Python测试）
__pycache__/
*.pyc
*.pyo
*.pyd

# 5. 模型文件 / 大文件（YOLO / 训练权重）
*.pt
*.pth
*.onnx
*.bin
*.engine

# 6. 日志 / 数据 / 临时图片
log/
logs/
*.log
temp/
tmp/
*.jpg~
*.png~
*.avi
*.mp4

# 7. 你之前出现的多余测试文件
test_*.txt
*.py.txt
camera_test*
temp_*